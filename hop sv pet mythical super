-- Xử lý kết quả kiểm tra
if foundMythical then
    print("=========================================")
    print("[TEST THÀNH CÔNG] ĐÃ TÌM THẤY SERVER CÓ PET MYTHICAL: " .. detectedPetName)
    print("[STATUS] DỪNG SERVER HOP. BỒ CÓ THỂ BẬT SCRIPT FARM CHÍNH Ở ĐÂY!")
    print("=========================================")
else
    print("[Thông báo] Server này toàn Pet cùi (Common/Rare). Chuẩn bị nhảy sau 3 giây...")
    task.wait(3)
    serverHop()
end
