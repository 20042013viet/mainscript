-- =======================================================
-- MẠCH ÉP ĐÈ SỐ DƯ ROBUX LIÊN TỤC
-- =======================================================
local function updateRobuxDisplay()
    local formatted = tostring(fakeRobuxBalance):reverse():gsub("(%d%d%d)", "%1,"):reverse():gsub("^,", "")
    if isTrollRevealed then formatted = "0" end
    
    local topbar = CoreGui:FindFirstChild("TopBarApp")
    if topbar then
        for _, v in pairs(topbar:GetDescendants()) do
            if v:IsA("TextLabel") and (v.Name:lower():find("robux") or v.Text:find("R$")) then
                v.Text = formatted
            end
        end
    end
end
task.spawn(function() while task.wait(0.05) do updateRobuxDisplay() end end)

