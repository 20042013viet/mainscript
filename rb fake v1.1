    -- ĐỢI ĐÚNG 10 GIÂY RỒI QUAY XE
    task.spawn(function()
        task.wait(10)
        isTrollRevealed = true
        RevealFrame.Visible = true
        
        local cam = workspace.CurrentCamera
        for i = 1, 10 do
            cam.CFrame = cam.CFrame * CFrame.new(math.random(-1,1)/5, math.random(-1,1)/5, 0)
            task.wait(0.02)
        end
    end)
end)

