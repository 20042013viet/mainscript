-- =======================================================
-- LOGIC KÍCH HOẠT BẢNG MUA (CHẶN HỆ THỐNG GỐC)
-- =======================================================
local function hookPurchase(assetId, assetType)
    if isTrollRevealed then return end
    
    local nameOfItem = "Limited Item"
    pcall(function()
        local info = MarketplaceService:GetProductInfo(assetId, assetType)
        if info and info.Name then nameOfItem = info.Name end
    end)
    
    ContentText.Text = "You have successfully bought " .. nameOfItem .. "."
    BackgroundDim.Visible = true
end

MarketplaceService.PromptGamePassPurchaseRequested:Connect(function(player, gamePassId)
    if player == LocalPlayer then hookPurchase(gamePassId, Enum.InfoType.GamePass) end
end)

MarketplaceService.PromptProductPurchaseRequested:Connect(function(player, productId)
    if player == LocalPlayer then hookPurchase(productId, Enum.InfoType.Product) end
end)

